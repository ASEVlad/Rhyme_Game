APP_PASSWORD=change-me
AUTH_SECRET=generate-with-openssl-rand-hex-32

# Google Gemini (free tier) — powers rhyme generation and beat metadata.
# Get keys at https://aistudio.google.com/apikey (free tier needs no billing).
# Add one key as GEMINI_API_KEY, or several numbered keys to rotate across
# free-tier rate limits: GEMINI_API_KEY1, GEMINI_API_KEY2, …
# Without any key, the app serves built-in fallback rhymes.
GEMINI_API_KEY=AIza...

# Invite-only gate for /login. When set, only visitors who land on
# /login?invite=<code> (or who already have the matching cookie) see
# the sign-in form. Strangers see a "closed beta" page. Leave empty or
# unset to make /login publicly visible. Recommended: ~16 random chars.
INVITE_CODE=

# Postgres connection string. Required for the NextAuth adapter and for
# the /api/waitlist route to persist signups. Without it, /api/waitlist
# returns 503.
POSTGRES_URL=postgres://user:pass@host:5432/dbname

# Comma-separated allowlist for Google sign-in. Only these emails can sign in.
ALLOWED_EMAILS=you@example.com,teammate@example.com

# From address used by Resend for both magic-link sign-in (if re-enabled)
# and waitlist notification emails.
EMAIL_FROM=noreply@yourdomain.com

# Resend API key. Used by the NextAuth Resend provider AND by the waitlist
# notification helper. If unset, waitlist signups still persist but no
# notification email is sent.
AUTH_RESEND_KEY=re_...

# Operator address that receives a notification email each time a fresh
# email joins the waitlist. If unset, signups still persist silently.
WAITLIST_NOTIFY_EMAIL=you@example.com

# Optional: override the canonical site URL used for OG image absolute paths.
# Defaults to https://rhymefor.fun. Set this on Vercel preview deployments
# (e.g. NEXT_PUBLIC_SITE_URL=https://your-preview.vercel.app) so OG unfurlers
# load the preview's image instead of production's.
NEXT_PUBLIC_SITE_URL=https://rhymefor.fun

# --- Waitlist auto-release (docs/superpowers/specs/2026-05-29-waitlist-auto-release-design.md) ---
# Shared secret the systemd timer presents to POST /api/cron/release-waitlist.
# Generate with: openssl rand -hex 32. The endpoint is internet-facing, so this
# token is the ONLY thing protecting it. The route fails closed if this is unset.
CRON_SECRET=
# How many oldest pending waitlisters each cron run accepts + emails. Default 20.
WAITLIST_DAILY_BATCH=20
# Set to "true" to open registration to everyone: decideSignIn then accepts every
# valid email, and the next cron run drains the entire remaining backlog.
REGISTRATION_OPEN=
